{
  "manifest_version": 3,
  "name": "AutoFill Job Applications",
  "version": "1.1",
  "description": "Auto-fills job application forms and generates AI answers.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*"
  ],
  "action": {
    "default_title": "Open side panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*"
      ],
      "js": [
        "atsStrategies/genericStrategy.js",
        "atsStrategies/greenhouseStrategy.js",
        "atsStrategies/leverStrategy.js",
        "atsStrategies/workdayStrategy.js",
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}